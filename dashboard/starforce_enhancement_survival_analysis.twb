      <column caption='Advantage Avg (Overall)' datatype='real' default-format='n#,##0.0;-#,##0.0' name='[Calculation_1849972977086468]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED :&#13;&#10;AVG(&#13;&#10;IF [policy] = &quot;advantage&quot;&#13;&#10;THEN [mean_tries]&#13;&#10;END&#13;&#10;)&#13;&#10;}' />
      </column>
      <column caption='Goal Achievement Rate (Overall)' datatype='real' default-format='p0.0%' name='[Calculation_1849972977946629]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED :&#13;&#10;AVG(&#13;&#10;IF [policy] = &quot;advantage&quot;&#13;&#10;THEN 1 - [dropout_rate]&#13;&#10;END&#13;&#10;)&#13;&#10;}' />
      </column>
      <column caption='Adv Median' datatype='integer' name='[Calculation_1892579502850056]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [union_segment] :&#13;&#10;    MAX(IF [policy]=&quot;advantage&quot; THEN [median_survival_time] END)&#13;&#10;}' />
      </column>
      <column caption='Base Median' datatype='integer' name='[Calculation_1892579502956553]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [union_segment] :&#13;&#10;    MAX(IF [policy]=&quot;baseline&quot; THEN [median_survival_time] END)&#13;&#10;}' />
      </column>
      <column caption='Median Survival Increase' datatype='integer' name='[Calculation_1892579503026186]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1892579502850056] - [Calculation_1892579502956553]' />
      </column>
      <column caption='Median Increase Label' datatype='string' name='[Calculation_1892579505061899]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;+&quot; + STR([Calculation_1892579503026186])' />
      </column>
      <column caption='Median Interpretation' datatype='string' name='[Calculation_1892579505709068]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1892579503026186] &gt; 0 THEN&#13;&#10;&quot;정책 효과 존재&quot;&#13;&#10;ELSE&#13;&#10;&quot;유의미한 변화 없음&quot;&#13;&#10;END' />
      </column>
      <column caption='Goal Survival Increase' datatype='real' default-format='p0.0%' name='[Calculation_1892579507154957]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [union_segment] :&#13;&#10;    MAX(IF [policy]=&quot;advantage&quot; THEN [goal_survival_probability] END)&#13;&#10;}&#13;&#10;-&#13;&#10;{ FIXED [union_segment] :&#13;&#10;    MAX(IF [policy]=&quot;baseline&quot; THEN [goal_survival_probability] END)&#13;&#10;}' />
      </column>
      <column caption='Goal Increase Label' datatype='string' name='[Calculation_1892579507916814]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1892579507154957] &gt; 0 THEN&#13;&#10;&quot;+&quot; &#13;&#10;END&#13;&#10;+&#13;&#10;STR(ROUND([Calculation_1892579507154957]*100,1))&#13;&#10;+&#13;&#10;&quot;%p&quot;' />
      </column>
      <column caption='Baseline Goal' datatype='real' default-format='p0.0%' name='[Calculation_1892579508187151]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [union_segment] :&#13;&#10;    MAX(IF [policy]=&quot;baseline&quot; THEN [goal_survival_probability] END)&#13;&#10;}' />
      </column>
      <column caption='Advantage Goal' datatype='real' default-format='p0.0%' name='[Calculation_1892579508240400]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [union_segment] :&#13;&#10;    MAX(IF [policy]=&quot;advantage&quot; THEN [goal_survival_probability] END)&#13;&#10;}' />
      </column>
      <column caption='Goal Policy Effect Interpretation' datatype='string' name='[Calculation_1892579508666385]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1892579507154957] &gt; 0 THEN&#13;&#10;&quot;→ 정책 효과 존재&quot;&#13;&#10;ELSE&#13;&#10;&quot;→ 유의미한 변화 없음&quot;&#13;&#10;END' />
      </column>
      <column caption='Avg Attempts Gain' datatype='real' default-format='*+0.0;-0.0' name='[Calculation_2357948097843200]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [union_segment] :&#13;&#10;    MAX(IF [policy] = &quot;advantage&quot; THEN [mean_tries] END)&#13;&#10;}&#13;&#10;-&#13;&#10;{ FIXED [union_segment] :&#13;&#10;    MAX(IF [policy] = &quot;baseline&quot; THEN [mean_tries] END)&#13;&#10;}' />
      </column>
      <column caption='Median Survival Gain' datatype='integer' default-format='*+0;-0' name='[Calculation_2357948098015233]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [union_segment] :&#13;&#10;    MAX(IF [policy] = &quot;advantage&quot; THEN [median_survival_time] END)&#13;&#10;}&#13;&#10;-&#13;&#10;{ FIXED [union_segment] :&#13;&#10;    MAX(IF [policy] = &quot;baseline&quot; THEN [median_survival_time] END)&#13;&#10;}' />
      </column>
      <column caption='Goal Completion Gain' datatype='real' name='[Calculation_2357948098146306]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [union_segment] :&#13;&#10;    MAX(IF [policy] = &quot;advantage&quot; THEN [goal_survival_probability] END)&#13;&#10;}&#13;&#10;-&#13;&#10;{ FIXED [union_segment] :&#13;&#10;    MAX(IF [policy] = &quot;baseline&quot; THEN [goal_survival_probability] END)&#13;&#10;}' />
      </column>
      <column caption='Goal Completion Gain %p' datatype='real' default-format='*+0.0&quot;%p&quot;;-0.0&quot;%p&quot;' name='[Calculation_2357948098232323]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_2357948098146306] * 100' />
      </column>
      <column caption='Segment Label' datatype='string' name='[Calculation_2357948098650116]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [union_segment]&#13;&#10;WHEN &quot;high_union&quot; THEN &quot;High Union&quot;&#13;&#10;WHEN &quot;mid_union&quot; THEN &quot;Mid Union&quot;&#13;&#10;WHEN &quot;low_union&quot; THEN &quot;Low Union&quot;&#13;&#10;END' />
      </column>
      <column caption='Goal Completion Label' datatype='string' name='[Calculation_2357948101279749]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_2357948098232323] &gt; 0 THEN&#13;&#10;&quot;+&quot; + STR(ROUND([Calculation_2357948098232323],1)) + &quot;%p&quot;&#13;&#10;ELSE&#13;&#10;STR(ROUND([Calculation_2357948098232323],1)) + &quot;%p&quot;&#13;&#10;END' />
