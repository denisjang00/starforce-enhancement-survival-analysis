              <calculation class='tableau' formula='IF FLOAT([p_value]) &lt; 0.001 THEN&#13;&#10;&quot;&lt; 0.001&quot;&#13;&#10;ELSE&#13;&#10;STR(ROUND(FLOAT([p_value]), 3))&#13;&#10;END' />
            </column>
